# Backend API URL (used by Next.js route handlers server-side)
BRAIN_API_URL=http://localhost:9200

# Bearer token for the backend API (server-side only, never expose to client)
API_KEY=your-api-key-here

# Next.js public app URL (used by SSR to call the proxy with absolute URL)
# Defaults to http://localhost:3000 if not set
NEXT_PUBLIC_APP_URL=http://localhost:3000
