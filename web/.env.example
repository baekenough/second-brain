# URL of the second-brain Go backend (server-side only — not exposed to client)
BRAIN_API_URL=http://localhost:9200

# Fallback: kept for backward compatibility (avoid in production — NEXT_PUBLIC_ vars are bundled into client JS)
# NEXT_PUBLIC_API_URL=http://localhost:9200

# Public URL of the Next.js app itself — used by server components to call the
# /api proxy with an absolute URL (required because fetch() on the server needs
# absolute URLs). Defaults to http://localhost:3000 when not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API key for backend authentication (server-side only, never expose to client)
API_KEY=your-api-key-here
