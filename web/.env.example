# Backend API URL (used by Next.js route handlers server-side)
BRAIN_API_URL=http://localhost:9200

# Bearer token for the backend API (server-side only, never expose to client)
API_KEY=your-api-key-here

# Next.js public app URL (used by SSR to call the proxy with absolute URL)
# Defaults to http://localhost:3000 if not set
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── GitHub OAuth (Auth.js v5 / next-auth) ────────────────────────────────────
# JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:       https://<your-domain>
# Authorization callback URL: https://<your-domain>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated list of GitHub usernames allowed to sign in.
# Leave empty (or unset) to DENY all users.
# Example: ALLOWED_GITHUB_USERS=alice,bob,carol
ALLOWED_GITHUB_USERS=

# ─── Reverse-proxy / tunnel auth (REQUIRED when behind cloudflared or any proxy) ──
# Auth.js needs to know the public origin to build correct OAuth callback URLs.
# Without AUTH_URL the callback URL will resolve to the internal container address
# and GitHub OAuth will reject it.
AUTH_URL=https://your-domain.example
# Tell Auth.js to trust the X-Forwarded-Host / X-Forwarded-Proto headers
# forwarded by the reverse proxy (cloudflared, nginx, etc.).
# Must be "true" whenever the app runs behind a proxy.
AUTH_TRUST_HOST=true
