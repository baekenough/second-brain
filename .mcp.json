{
  "mcpServers": {
    "ontology-rag": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "ontology_rag.mcp_server"
      ],
      "env": {
        "ONTOLOGY_DIR": ".claude/ontology"
      }
    },
    "eraser": {
      "type": "http",
      "url": "https://app.eraser.io/api/mcp"
    }
  }
}
