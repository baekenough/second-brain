# Server
PORT=9200

# API Bearer token enforced on /api/v1/* (leave empty to disable auth in dev).
# Generate a strong value with:  openssl rand -hex 32
API_KEY=

# PostgreSQL (pgvector/pgvector:pg16)
DATABASE_URL=postgres://brain:brain@localhost:5432/second_brain?sslmode=disable

# Embedding — issue #34: OpenAI direct (text-embedding-3-small, sk- key)
#
# Routing decision: embeddings call OpenAI directly using a DEDICATED key set
# in EMBEDDING_API_KEY.  cliproxy is chat-only (returns 404 on /v1/embeddings)
# and must NOT be used for this path.
#
# Disabling embeddings: leave EMBEDDING_API_KEY and CLIPROXY_AUTH_FILE empty.
# Search degrades gracefully to full-text-search (FTS) — no crash, no data loss.
#
# Changing EMBEDDING_DIM after data exists requires draining all embeddings first
# (see docs/embedding-dimension.md).  Set BEFORE the first migration.
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# Embedding vector dimension — must match the model's output size.
# text-embedding-3-small  → 1536 (default, backward-compatible)
# multilingual-e5-small-ko (dragonkue/multilingual-e5-small-ko) → 384
EMBEDDING_DIM=1536
# Dedicated OpenAI API key for embeddings (recommended — keeps embedding costs
# separate from chat/LLM costs and allows independent key rotation).
# Use a sk-... key scoped to the embeddings API only.
EMBEDDING_API_KEY=
# Legacy: CliProxyAPI OAuth token file (chat proxies only).
# Only used when EMBEDDING_API_KEY is empty.  cliproxy does NOT support
# /v1/embeddings — use EMBEDDING_API_KEY for OpenAI direct instead.
CLIPROXY_AUTH_FILE=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_ORG=

# Google Drive service account (optional)
# Paste the contents of your service_account.json as a single line.
GDRIVE_CREDENTIALS_JSON=

# Notion (optional)
NOTION_TOKEN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Filesystem (local Google Drive sync folder)
FILESYSTEM_PATH=/Users/user/Google Drive/공유 드라이브/<shared-drive>
FILESYSTEM_ENABLED=true

# Additional directory names to skip (merged with built-in defaults:
# .git, node_modules, dist, .next, .omc, .sisyphus, .claude).
# Name-level match, comma-separated. Use this to exclude security-sensitive
# directories (e.g. keys), large caches (.venv, vendor), or editor metadata.
FILESYSTEM_EXCLUDE_DIRS=

# Additional file extensions to skip (merged with built-in defaults: .bak,
# .gitkeep, .plist, .lock, .DS_Store). Comma-separated; leading dot optional.
# Use to exclude source code from being indexed as full text (e.g.
# .js,.ts,.py) when the collector is pointed at a note-oriented vault that
# contains nested code projects.
FILESYSTEM_EXCLUDE_EXTS=

# Scheduler
# How often collectors run. Examples: 1h, 30m, 6h
COLLECT_INTERVAL=1h

# --- Whisper (OpenAI-compatible ASR — audio transcription) ---
#
# Two deployment modes (see deploy/whisper-lb/README.md for full details):
#
#   Mode A — Non-distributed / local (default):
#     Whisper runs as the 'whisper' service in docker-compose.local.yml.
#     WHISPER_API_URL=http://whisper:8000/v1
#     WHISPER_CONCURRENCY=1
#
#   Mode B — Distributed 2-node LB (home servers via Tailscale):
#     Caddy LB on the collector host (<lb-host>:8770) fronts faster-whisper backends.
#     WHISPER_API_URL=http://<lb-host>:8770/v1
#     WHISPER_CONCURRENCY=2
#
# Base URL of the whisper API (must end with /v1).
WHISPER_API_URL=http://whisper:8000/v1
# Number of concurrent transcription requests the collector sends.
# 1 for single-instance; increase to match the number of LB backends.
WHISPER_CONCURRENCY=1
# BCP-47 language code for transcription. Use "ko" for Korean.
WHISPER_LANGUAGE=ko
# HuggingFace model repo ID used by the whisper server.
WHISPER_MODEL=Systran/faster-whisper-medium
# Host path to the directory containing audio files for transcription.
WHISPER_AUDIO_DIR=/data/call

# --- Discord collector (issue #27) ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_GUILD_IDS=comma_separated_guild_ids
DISCORD_COLLECT_INTERVAL=5m
DISCORD_MENTION_RESPONSE_ENABLED=true

# --- LLM (Discord RAG answer generation + document summarization) ---
#
# Required for summarization (title_summary / bullet_summary / summary_embedding):
#   LLM_API_KEY  — must be set; without it the SummarizerWorker is disabled and
#                  logs "summarizer worker disabled — LLM not configured (set LLM_API_KEY)".
#   LLM_MODEL    — model used for summarization and Discord RAG (default: gpt-4o-mini).
#   EMBEDDING_API_KEY — required for summary_embedding generation (vector search over
#                       summaries).  Without it summary text is stored but summary
#                       vectors are not generated and summary-vec hybrid search is disabled.
#
# Note: SUMMARIZER_ENABLED=false disables the summarizer on a specific replica
# (e.g. all k8s collector pods except a dedicated single summarizer pod).
#
# Base URL for chat completions. Defaults to EMBEDDING_API_URL when unset.
# For cliproxy: same host as EMBEDDING_API_URL (e.g. https://api.openai.com/v1)
LLM_API_URL=
# Static API key for LLM requests. Defaults to EMBEDDING_API_KEY when unset.
# Leave empty to use cliproxy OAuth file instead (LLM_CLIPROXY_AUTH_FILE or CLIPROXY_AUTH_FILE).
# REQUIRED for document summarization (SummarizerWorker).
LLM_API_KEY=
# Cliproxy OAuth file for LLM requests. Defaults to CLIPROXY_AUTH_FILE when unset.
# Set this only when the LLM endpoint uses a different cliproxy account than embeddings.
LLM_CLIPROXY_AUTH_FILE=
# Model name used for chat completions and document summarization.
# Default: gpt-4o-mini  (cost-effective; supports JSON mode required by SummarizerWorker)
LLM_MODEL=gpt-4o-mini
# Maximum tokens in the generated answer (default: 1500)
LLM_MAX_TOKENS=1500
# Sampling temperature — 0.0 (deterministic) to 1.0 (creative). Default: 0.3
LLM_TEMPERATURE=0.3

# --- Summarizer worker control ---
# Set SUMMARIZER_ENABLED=false on collector replicas that should NOT run
# summarization (e.g. when a dedicated single-replica summarizer pod is used).
# Default: true (all replicas run summarization; FOR UPDATE SKIP LOCKED prevents
# duplicate work across replicas).
SUMMARIZER_ENABLED=true

# Coverage gate for summary-vector hybrid search (#63):
# SummaryVec RRF signal is enabled only when this fraction (0–1) of active
# documents have a non-NULL summary_embedding.  Default: 0.80 (80%).
# Lower this value if you want the signal active sooner during backfill.
SUMMARY_VEC_COVERAGE_THRESHOLD=0.80
