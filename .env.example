# Server
PORT=9200

# API Bearer token enforced on /api/v1/* (leave empty to disable auth in dev).
# Generate a strong value with:  openssl rand -hex 32
API_KEY=

# PostgreSQL (pgvector/pgvector:pg16)
DATABASE_URL=postgres://brain:brain@localhost:5432/second_brain?sslmode=disable

# Embedding (auto-reads from CliProxyAPI auth file)
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# Option 1: Auto-read from CliProxyAPI Codex OAuth token
CLIPROXY_AUTH_FILE=
# Option 2: Manual API key (overrides CLIPROXY_AUTH_FILE)
EMBEDDING_API_KEY=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_ORG=

# Google Drive service account (optional)
# Paste the contents of your service_account.json as a single line.
GDRIVE_CREDENTIALS_JSON=

# Notion (optional)
NOTION_TOKEN=

# Filesystem (local Google Drive sync folder)
FILESYSTEM_PATH=/Users/sangyi/Google Drive/공유 드라이브/Vibers.AI
FILESYSTEM_ENABLED=true

# Additional directory names to skip (merged with built-in defaults:
# .git, node_modules, dist, .next, .omc, .sisyphus, .claude).
# Name-level match, comma-separated. Use this to exclude security-sensitive
# directories (e.g. keys), large caches (.venv, vendor), or editor metadata.
FILESYSTEM_EXCLUDE_DIRS=

# Additional file extensions to skip (merged with built-in defaults: .bak,
# .gitkeep, .plist, .lock, .DS_Store). Comma-separated; leading dot optional.
# Use to exclude source code from being indexed as full text (e.g.
# .js,.ts,.py) when the collector is pointed at a note-oriented vault that
# contains nested code projects.
FILESYSTEM_EXCLUDE_EXTS=

# Scheduler
# How often collectors run. Examples: 1h, 30m, 6h
COLLECT_INTERVAL=1h

# --- Discord collector (issue #27) ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_GUILD_IDS=comma_separated_guild_ids
DISCORD_COLLECT_INTERVAL=5m
DISCORD_MENTION_RESPONSE_ENABLED=true

# --- LLM (Discord RAG answer generation) ---
# Base URL for chat completions. Defaults to EMBEDDING_API_URL when unset.
# For cliproxy: same host as EMBEDDING_API_URL (e.g. https://api.openai.com/v1)
LLM_API_URL=
# Static API key. Defaults to EMBEDDING_API_KEY when unset.
# Leave empty to use cliproxy OAuth file instead (LLM_CLIPROXY_AUTH_FILE or CLIPROXY_AUTH_FILE).
LLM_API_KEY=
# Cliproxy OAuth file for LLM requests. Defaults to CLIPROXY_AUTH_FILE when unset.
# Set this only when the LLM endpoint uses a different cliproxy account than embeddings.
LLM_CLIPROXY_AUTH_FILE=
# Model name used for chat completions.
LLM_MODEL=gpt-4o-mini
# Maximum tokens in the generated answer (default: 1500)
LLM_MAX_TOKENS=1500
# Sampling temperature — 0.0 (deterministic) to 1.0 (creative). Default: 0.3
LLM_TEMPERATURE=0.3
