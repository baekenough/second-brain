# Sidecar env for docker-compose.laptop-collector.yml.
# Copy to .env.laptop-collector (git-ignored) and fill in real values, then:
#   docker compose --env-file .env.laptop-collector -f docker-compose.laptop-collector.yml up -d

# Postgres password for the `brain` user on host1 (NodePort 30032). Must match
# POSTGRES_PASSWORD in the deployed k8s Secret.
POSTGRES_PASSWORD=CHANGE_ME

# Optional OpenAI-compatible embedding API key. Leave empty to fall back to
# CliProxy OAuth or disable embedding entirely.
EMBEDDING_API_KEY=

# --- 호스트 경로 (docker-compose.laptop-collector.yml 볼륨 마운트용) ---
# Linux/Windows 등 macOS 이외 환경에서 실행 시 실제 경로로 변경하세요.
# (미설정 시 compose 파일의 :- 기본값이 macOS 경로로 폴백됩니다)
# 홈 디렉토리 절대 경로 (~/.claude, ~/.codex, ~/.gemini 마운트 베이스)
HOST_HOME=/Users/user
# 워크스페이스 루트 절대 경로 (/data/drive/workspace 에 마운트됨)
WORKSPACE_DIR=/Users/user/workspace
