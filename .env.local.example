# ============================================
# second-brain 로컬 풀스택 환경설정 예시
# ============================================
# 사용법:
#   1. 이 파일을 .env.local 로 복사하세요:
#        cp .env.local.example .env.local
#   2. EMBEDDING_API_KEY 에 OpenAI API 키를 채우세요 (sk-... 형식).
#   3. docker compose -f docker-compose.local.yml up -d --build
# ============================================

# >>> 반드시 채워야 하는 값 <<<
# OpenAI API 키 (text-embedding-3-small 호출에 사용)
EMBEDDING_API_KEY=

# Ingest API authentication token (used by /api/v1/ingest/messages and /api/v1/ingest/recording).
# IMPORTANT: The Android app's Settings screen must be configured with the SAME value.
# If left empty, authentication is DISABLED — acceptable for local dev only.
# Production deployments (exposed via external tunnel) MUST set this to a strong random token.
API_KEY=

# HuggingFace 토큰 (diarization 서비스의 gated 모델 다운로드에 필수)
# pyannote/speaker-diarization-3.1 을 처음 사용하기 전에:
#   1. https://huggingface.co/pyannote/speaker-diarization-3.1 — 약관 동의
#   2. https://huggingface.co/pyannote/segmentation-3.0 — 약관 동의
#   3. https://huggingface.co/settings/tokens — 읽기 토큰 생성 후 아래에 입력
# 모델 캐시 후에는 토큰 없이도 동작하지만, 캐시 미스 시 인증 실패할 수 있습니다.
# (미설정 시 compose 경고 없이 공백 처리됩니다; diarization 은 비활성화 상태로 기동)
HF_TOKEN=

# --- 아래는 기본값. 로컬 Compose 에서는 수정 불필요 ---

# 임베딩 (OpenAI text-embedding-3-small, 1536 차원)
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# DB (compose 내부 postgres 서비스. 호스트명 = 서비스명 'postgres')
DATABASE_URL=postgres://brain:brain@postgres:5432/second_brain?sslmode=disable

# 마이그레이션 디렉토리 (server/collector 컨테이너 내부 경로)
MIGRATIONS_DIR=/app/migrations

# API 서버 포트
PORT=8080

# Collector 설정
COLLECTOR_INSTANCE=laptop
COLLECT_INTERVAL=1m

# SQLite 소스 경로 (컨테이너 내부 경로. compose 가 호스트 파일을 ro 마운트)
SECRETARY_DB_PATH=/data/secretary.db
LLM_MEMORY_DB_PATH=/data/llm-memory.sqlite

# --- 호스트 경로 (docker-compose.local.yml 볼륨 마운트용) ---
# 아래 두 변수는 호스트 파일시스템의 절대 경로입니다.
# Linux/Windows 등 macOS 이외 환경에서 실행 시 실제 경로로 변경하세요.
# (미설정 시 compose 파일의 :- 기본값이 macOS 경로로 폴백됩니다)
SECRETARY_DB_HOST_PATH=/Users/user/workspace/private/secretary/assistant/secretary.db
LLM_MEMORY_DB_HOST_PATH=/Users/user/workspace/llm-memory/data/memory.sqlite
# Collector가 ro 마운트하는 호스트 개인데이터 경로 (사용자 환경에 맞게 설정)
# GMAIL_HOST_PATH=/Users/<you>/workspace/private/secretary/gmail
# CALENDAR_HOST_PATH=/Users/<you>/workspace/private/secretary/calendar
