<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ──────────────────────────────────────────────────────────────────
         PERMISSIONS
         All three groups are sensitive; the user grants them at first-run.
         No FOREGROUND_SERVICE — WorkManager does not need it (battery MUST).
    ────────────────────────────────────────────────────────────────────── -->

    <!-- SMS reading -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Call-log reading -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Recording files (pre-API-33 devices) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Recording files (API 33+ scoped-storage) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Network access for uploading batches -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Reschedule WorkManager after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery-optimization exemption: keeps WorkManager periodic work alive on Samsung One UI.
         Required for ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS intent.
         Google Play policy: permitted for apps with legitimate background-sync needs. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".SecondBrainApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SecondBrainPush">

        <!-- Launcher: dashboard-first MainActivity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SettingsActivity kept for backward compatibility; no longer the launcher -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- WorkManager initializer (use default initializer; no custom provider needed) -->

    </application>

</manifest>
