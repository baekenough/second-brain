<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="88dp">

        <!-- App bar title -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:paddingBottom="16dp" />

        <!-- ─── Connection status card ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card header: icon + title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_link"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/card_connection_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />
                </LinearLayout>

                <!-- Status row: dot + status text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_status_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_status_dot"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_connection_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:text="@string/status_needs_config" />
                </LinearLayout>

                <!-- Server host subtitle -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_server_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Background execution status card ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_background_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card header: icon + title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sync"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/card_background_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />
                </LinearLayout>

                <!-- Status row: dot + status text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_bg_status_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_status_dot"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_bg_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                </LinearLayout>

                <!-- Exemption button: visible only when NOT exempt -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_disable_battery_optimization"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/btn_disable_battery_optimization"
                    android:visibility="gone" />

                <!-- Samsung-specific hint: static, always visible -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/bg_samsung_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Last sync card ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_last_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sync"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/card_last_sync_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />
                </LinearLayout>

                <!-- Last sync time -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_last_sync"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:text="@string/last_sync_never" />

                <!-- Auto interval -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_sync_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp" />

                <!-- Sync progress indicator -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_sync"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:trackCornerRadius="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Stats card (three tiles) ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card header -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/card_stats_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:layout_marginBottom="12dp" />

                <!-- Three stat tiles in a row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- SMS tile -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_message"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_sms_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="?attr/textAppearanceTitleLarge" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stats_sms_label"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Calls tile -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_call"
                            app:tint="?attr/colorSecondary"
                            android:contentDescription="@null"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_calls_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="?attr/textAppearanceTitleLarge" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stats_calls_label"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Recordings tile -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_mic"
                            app:tint="?attr/colorTertiary"
                            android:contentDescription="@null"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tv_recordings_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="?attr/textAppearanceTitleLarge" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stats_recordings_label"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Sync Now button ─── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_sync_now"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            app:icon="@drawable/ic_sync"
            app:iconGravity="textStart" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
