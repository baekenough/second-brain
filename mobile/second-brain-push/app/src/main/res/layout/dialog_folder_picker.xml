<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/colorSurface">

    <!-- Dialog title -->
    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/folder_picker_title"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:paddingBottom="8dp" />

    <!-- Current path display -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_current_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="/storage/emulated/0"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:ellipsize="start"
        android:singleLine="true"
        android:paddingBottom="4dp" />

    <!-- "Up" button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_up"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/folder_picker_up"
        app:icon="@drawable/ic_folder_up"
        android:paddingStart="0dp"
        android:layout_marginBottom="4dp" />

    <!-- Folder list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_folders"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:clipToPadding="false" />

    <!-- Empty hint -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_empty_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/folder_picker_empty"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:visibility="gone"
        android:padding="16dp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/folder_picker_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_folder"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/folder_picker_select" />

    </LinearLayout>

</LinearLayout>
