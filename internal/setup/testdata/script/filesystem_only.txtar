# Test: WriteEnv produces a valid .env for filesystem channel only.
# Uses the registered "envwrite" command (see wizard_test.go TestMain) which
# calls setup.WriteEnv directly — this avoids the huh TTY requirement while
# still exercising the atomic-write + file-mode path end-to-end.
#
# Validates:
#   1. FILESYSTEM_PATH is written
#   2. FILESYSTEM_ENABLED=true is hardcoded
#   3. The wizard header comment is present

envwrite FILESYSTEM_ENABLED=true,FILESYSTEM_PATH=/tmp/docs .env
exists .env
grep 'FILESYSTEM_ENABLED=true' .env
grep 'FILESYSTEM_PATH=/tmp/docs' .env
grep 'Generated by second-brain setup wizard' .env
